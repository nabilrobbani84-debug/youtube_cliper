{
  "name": "youclip-clone",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "clean:next": "node scripts/clean-next.cjs",
    "dev:frontend": "next dev -p 3000",
    "dev:backend": "node server/server.js",
    "predev": "npm run clean:next",
    "dev": "concurrently -k \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "next build",
    "start:frontend": "next start -p 3000",
    "start:backend": "node server/server.js",
    "start": "concurrently -k \"npm run start:frontend\" \"npm run start:backend\""
  },
  "dependencies": {
    "ffmpeg-static": "^5.1.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "lucide-react": "^0.344.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
